# ─────────────────────────────────────────────
# StreamBox Pro — Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://brx:Qw3RtY77@localhost:5432/streambox"

# NextAuth.js secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-here-change-this"

# Your app URL (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# Optional: Production URL
# NEXTAUTH_URL="https://yourdomain.com"

# Node environment
NODE_ENV="development"

# Mercado Pago — PIX Payments
# Gere em: https://www.mercadopago.com.br/settings/account/credentials
MERCADOPAGO_ACCESS_TOKEN="TEST-XXXXXXXXXXXXXXXXXXXX"
